    {
      "application": "fp-avdelingsleder",
      "namespace": "teamforeldrepenger",
      "cluster": "prod-gcp"
    },
    {
      "application": "fpsak",
      "namespace": "teamforeldrepenger",
      "cluster": "prod-fss"
    },
    {
      "application": "fptilbake",
      "namespace": "teamforeldrepenger",
